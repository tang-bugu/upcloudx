{
  "name": "@upcloudx/ui",
  "version": "0.4.2",
  "description": "UpCloudX 通用业务 UI 组件库 & Hooks",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs"
  },
  "peerDependencies": {
    "dayjs": ">=1.11.0",
    "vue": ">=3.5.0"
  },
  "dependencies": {
    "@vueuse/core": "13.9.0",
    "@vueuse/integrations": "13.9.0",
    "radix-vue": "1.9.17",
    "universal-cookie": "7.2.2"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "5.2.4",
    "dayjs": "1.11.18",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vite-plugin-css-injected-by-js": "3.5.2",
    "vite-plugin-dts": "4.5.4",
    "vitepress": "1.6.4",
    "vue": "3.5.22"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tang-bugu/upcloudx.git"
  },
  "license": "MIT"
}
